rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own user doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Comics: owner can do everything; public can read public+finished comics
    match /comics/{comicId} {
      allow read: if request.auth != null && resource.data.authorId == request.auth.uid;
      allow read: if resource.data.isPublic == true && resource.data.status == 'finished';
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid ||
        // Allow reaction updates from anyone (only reactions field changes)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'updatedAt'])
      );
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
  }
}
